{
  "name": "@matthewkerns/software-development-best-practices-guide",
  "version": "1.5.2",
  "description": "A comprehensive, project-agnostic guide synthesizing principles from Code Complete 2, Clean Code, and Clean Architecture — plus shared agentic-coding tooling (skills, agents, hooks, the mango-tools MCP server, and a sync CLI)",
  "main": "index.js",
  "bin": {
    "mango-tools": "mcp/server.mjs",
    "bpg-sync": "bin/sync-claude-tooling.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatthewKerns/software-development-best-practices-guide.git"
  },
  "keywords": [
    "best-practices",
    "clean-code",
    "clean-architecture",
    "code-complete",
    "software-development",
    "documentation",
    "coding-standards"
  ],
  "author": "MatthewKerns",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MatthewKerns/software-development-best-practices-guide/issues"
  },
  "homepage": "https://github.com/MatthewKerns/software-development-best-practices-guide#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "01-foundations/**/*.md",
    "02-design-in-code/**/*.md",
    "03-clean-architecture/**/*.md",
    "04-quality-through-testing/**/*.md",
    "05-refactoring-and-improvement/**/*.md",
    "06-collaborative-construction/**/*.md",
    "07-agentic-coding/**/*.md",
    "08-project-management/**/*.md",
    "09-production-readiness/**/*.md",
    "09-production-readiness/**/*.yaml",
    "10-geist-gap-analysis-framework/**/*.md",
    "99-reference/**/*.md",
    "skills/**/*.md",
    "skills/**/*.py",
    "skills/**/*.yaml",
    "agents/**/*.md",
    "agentic-tooling/**/*.md",
    "agentic-tooling/**/*.sh",
    "agentic-tooling/**/*.json",
    "agentic-tooling/**/*.py",
    "mcp/**/*.mjs",
    "bin/**/*.mjs",
    "docs/**/*.md",
    "README.md",
    "CLAUDE.md",
    "INSTALL_AGENTIC_TOOLING.md",
    "LICENSE"
  ]
}
